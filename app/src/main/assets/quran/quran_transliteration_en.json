      "totalAyahs": 7,
      "ayahs": [
        {
          "surahNumber": 1,
          "ayahNumber": 1,
          "text": "Bismillahir rahmanir rahim"
        },
        {
          "surahNumber": 1,
          "ayahNumber": 2,
          "text": "Alhamdu lillahi rabbil alamin"
        },
        {
          "surahNumber": 1,
          "ayahNumber": 3,
          "text": "Ar rahmanir rahim"
        },
        {
          "surahNumber": 1,
          "ayahNumber": 4,
          "text": "Maliki yawmid din"
        },
        {
          "surahNumber": 1,
          "ayahNumber": 5,
          "text": "Iyyaka na'budu wa iyyaka nasta'in"
        },
        {
          "surahNumber": 1,
          "ayahNumber": 6,
          "text": "Ihdinas siratal mustaqim"
        },
        {
          "surahNumber": 1,
          "ayahNumber": 7,
          "text": "Siratal ladhina an'amta alayhim"
        }
      ]
