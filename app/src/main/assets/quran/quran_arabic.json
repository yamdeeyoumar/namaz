{
  "surahs": [
    {
      "surahNumber": 1,
      "surahNameArabic": "الفاتحة",
      "surahNameEnglish": "Al-Fatihah",
      "totalAyahs": 7,
      "ayahs": [
        {"surahNumber": 1, "ayahNumber": 1, "text": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"},
        {"surahNumber": 1, "ayahNumber": 2, "text": "الْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ"},
        {"surahNumber": 1, "ayahNumber": 3, "text": "الرَّحْمَٰنِ الرَّحِيمِ"},
        {"surahNumber": 1, "ayahNumber": 4, "text": "مَالِكِ يَوْمِ الدِّينِ"},
        {"surahNumber": 1, "ayahNumber": 5, "text": "إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ"},
        {"surahNumber": 1, "ayahNumber": 6, "text": "اهْدِنَا الصِّرَاطَ الْمُسْتَقِيمَ"},
        {"surahNumber": 1, "ayahNumber": 7, "text": "صِرَاطَ الَّذِينَ أَنْعَمْتَ عَلَيْهِمْ"}
      ]
    },
    {
      "surahNumber": 108,
      "surahNameArabic": "الكوثر",
      "surahNameEnglish": "Al-Kawthar",
      "totalAyahs": 3,
      "ayahs": [
        {"surahNumber": 108, "ayahNumber": 1, "text": "إِنَّا أَعْطَيْنَاكَ الْكَوْثَرَ"},
        {"surahNumber": 108, "ayahNumber": 2, "text": "فَصَلِّ لِرَبِّكَ وَانْحَرْ"},
        {"surahNumber": 108, "ayahNumber": 3, "text": "إِنَّ شَانِئَكَ هُوَ الْأَبْتَرُ"}
      ]
    },
    {
      "surahNumber": 112,
      "surahNameArabic": "الإخلاص",
      "surahNameEnglish": "Al-Ikhlas",
      "totalAyahs": 4,
      "ayahs": [
        {"surahNumber": 112, "ayahNumber": 1, "text": "قُلْ هُوَ اللَّهُ أَحَدٌ"},
        {"surahNumber": 112, "ayahNumber": 2, "text": "اللَّهُ الصَّمَدُ"},
        {"surahNumber": 112, "ayahNumber": 3, "text": "لَمْ يَلِدْ وَلَمْ يُولَدْ"},
        {"surahNumber": 112, "ayahNumber": 4, "text": "وَلَمْ يَكُنْ لَهُ كُفُوًا أَحَدٌ"}
      ]
    },
    {
      "surahNumber": 113,
      "surahNameArabic": "الفلق",
      "surahNameEnglish": "Al-Falaq",
      "totalAyahs": 5,
      "ayahs": [
        {"surahNumber": 113, "ayahNumber": 1, "text": "قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ"},
        {"surahNumber": 113, "ayahNumber": 2, "text": "مِنْ شَرِّ مَا خَلَقَ"},
        {"surahNumber": 113, "ayahNumber": 3, "text": "وَمِنْ شَرِّ غَاسِقٍ إِذَا وَقَبَ"},
        {"surahNumber": 113, "ayahNumber": 4, "text": "وَمِنْ شَرِّ النَّفَّاثَاتِ فِي الْعُقَدِ"},
        {"surahNumber": 113, "ayahNumber": 5, "text": "وَمِنْ شَرِّ حَاسِدٍ إِذَا حَسَدَ"}
      ]
    },
    {
      "surahNumber": 114,
      "surahNameArabic": "الناس",
      "surahNameEnglish": "An-Nas",
      "totalAyahs": 6,
      "ayahs": [
        {"surahNumber": 114, "ayahNumber": 1, "text": "قُلْ أَعُوذُ بِرَبِّ النَّاسِ"},
        {"surahNumber": 114, "ayahNumber": 2, "text": "مَلِكِ النَّاسِ"},
        {"surahNumber": 114, "ayahNumber": 3, "text": "إِلَٰهِ النَّاسِ"},
        {"surahNumber": 114, "ayahNumber": 4, "text": "مِنْ شَرِّ الْوَسْوَاسِ الْخَنَّاسِ"},
        {"surahNumber": 114, "ayahNumber": 5, "text": "الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِ"},
        {"surahNumber": 114, "ayahNumber": 6, "text": "مِنَ الْجِنَّةِ وَالنَّاسِ"}
      ]
    }
  ]
}
